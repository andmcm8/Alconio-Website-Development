# VERCEL DEPLOYMENT CONFIGURATION
# ------------------------------
# Add these variables to your Vercel Project Settings -> Environment Variables.
# DO NOT COMMIT THIS FILE TO GITHUB IF IT CONTAINS REAL CREDENTIALS.

# Google Analytics 4 Property ID (Find in GA4 Admin Settings)
GA_PROPERTY_ID=YOUR_PROPERTY_ID_HERE

# Google Cloud Service Account JSON (Minified as a single string)
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"alconio","private_key_id":"...","private_key":"...","client_email":"dashboard@alconio.iam.gserviceaccount.com"}
